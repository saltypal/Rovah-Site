---
import Layout from '~/layouts/PageLayout.astro';
import teamData from '~/data/teams';

const subdivisionColors = {
  'CS & AI': 'Blue',
  'Mechanical': 'Red',
  'Science': 'Green',
  'EC & EE': 'Pink',
  'Media': 'Pink'
};

const metadata = {
  title: 'Our Team',
  description: 'Meet the members of Rovah – the official rover team at Amrita Bengaluru Campus.',
};

type Member = { 
  name: string; 
  role: string; 
  subdivision?: string; 
  speciality: string | null;
  about: string | null;
  photo?: string | null;
  photoResolved?: string;
  socials: { github?: string; linkedin?: string; email?: string }
};

// Vite glob to find all images inside src/data/profilepic/
const images = import.meta.glob<{ default: ImageMetadata }>('/src/data/profilepic/*.{jpeg,jpg,png,gif,webp}');

async function resolvePhoto(photoName: string | null | undefined) {
  if (!photoName) return '';
  const path = `/src/data/profilepic/${photoName}`;
  if (images[path]) {
    const mod = await images[path]();
    return mod.default.src;
  }
  return '';
}

// Pre-resolve all photos at build time
const mentorRaw = teamData['Mentors']?.[0] as Member | undefined;
const mentor = mentorRaw ? {
  ...mentorRaw,
  photoResolved: await resolvePhoto(mentorRaw.photo)
} : undefined;

const allLeadsRaw = (teamData['TeamLead'] as Member[]) ?? [];
const allLeads = await Promise.all(allLeadsRaw.map(async (l) => ({
  ...l,
  photoResolved: await resolvePhoto(l.photo)
})));

const allPMsRaw = (teamData['Project Manager'] as Member[]) ?? [];
const allPMs = await Promise.all(allPMsRaw.map(async (p) => ({
  ...p,
  photoResolved: await resolvePhoto(p.photo)
})));

const adminLead = allLeads.find(l => l.role === 'Administrative Lead');
const techLead  = allLeads.find(l => l.role === 'Technical Lead');
const teamLeads = allLeads.filter(l => l.role === 'Team Lead');

const colorHexMap = {
  Red: '#ef4444',
  Blue: '#3b82f6',
  Green: '#22c55e',
  Pink: '#ec4899'
};

const subdivisionMap = [
  { key: 'CS and AI',  label: 'CS & AI',    teamLeadName: 'Chaturya' },
  { key: 'Science',    label: 'Science',     teamLeadName: 'Lohitashwa Talamanchi' },
  { key: 'Electrical', label: 'EC & EE',     teamLeadName: 'Prakhar' },
  { key: 'Mechanical', label: 'Mechanical',  teamLeadName: 'M Nikhil' },
  { key: 'Media',      label: 'Media',       teamLeadName: 'Pragathi L' },
].map(sub => ({
  ...sub,
  color: colorHexMap[subdivisionColors[sub.label as keyof typeof subdivisionColors]] || '#64748b'
}));

// Pre-resolve all subdivision members
const resolvedSubdivisions = {} as Record<string, Member[]>;
for (const sub of subdivisionMap) {
  const members = (teamData[sub.key] as Member[] | undefined) ?? [];
  resolvedSubdivisions[sub.key] = await Promise.all(members.map(async (m) => ({
    ...m,
    photoResolved: await resolvePhoto(m.photo)
  })));
}

function initials(name: string) {
  return name.split(' ').map(w => w[0]).slice(0, 2).join('').toUpperCase();
}
---

<Layout metadata={metadata}>
  <main class="team-page">

    <!-- PAGE HEADER -->
    <div class="team-header">
      <div class="team-header-text">
        <p class="tagline">Our People</p>
        <h1>Meet Team Odyssey</h1>
        <p class="subtitle">The talented people building our rover.</p>
      </div>

      <!-- VIEW TOGGLE -->
      <div class="view-toggle" role="group" aria-label="View mode">
        <button id="btn-org" class="toggle-btn active" aria-pressed="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="9" y="2" width="6" height="4" rx="1"/><rect x="2" y="10" width="6" height="4" rx="1"/><rect x="9" y="18" width="6" height="4" rx="1"/><rect x="16" y="10" width="6" height="4" rx="1"/><line x1="12" y1="6" x2="12" y2="10"/><line x1="5" y1="14" x2="12" y2="18"/><line x1="19" y1="14" x2="12" y2="18"/></svg>
          Org Chart
        </button>
        <button id="btn-grid" class="toggle-btn" aria-pressed="false">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
          Grid
        </button>
      </div>
    </div>

    <!-- ══════════════════ ORG CHART VIEW ══════════════════ -->
    <div id="view-org" class="view-pane org-wrap">
      
      <!-- Mentor floats top-right -->
      {mentor && (
        <div class="mentor-corner">
          <span class="mentor-label">Faculty Mentor</span>
          <div 
            class="pcard mentor-card interactive-card"
            data-name={mentor.name}
            data-role={mentor.role}
            data-speciality={mentor.speciality || ""}
            data-about={mentor.about || ""}
            data-photo={mentor.photoResolved || ""}
            data-github={mentor.socials.github}
            data-linkedin={mentor.socials.linkedin}
            data-email={mentor.socials.email}
            data-subdivision=""
            data-avatar-gradient="linear-gradient(135deg, #f59e0b, #d97706)"
          >
            <div class="pcard-info">
              <span class="pcard-name">{mentor.name}</span>
              <span class="pcard-role">{mentor.role}</span>
            </div>
            <div class="pcard-avatar" style={mentor.photoResolved ? `background: url(${mentor.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, #f59e0b, #d97706)`}>
              {!mentor.photoResolved && initials(mentor.name)}
            </div>
          </div>
        </div>
      )}

      <!-- Interactive Diagramming Grid Canvas -->
      <div class="org-canvas org-chart-bg">
        <div class="org-tree-wrapper">

          <!-- ── LEVEL 1: Technical Lead (Ekansh) ── -->
          <div class="org-root-row">
            {techLead && (
              <div class="root-node-container">
                  <div 
                    class="pcard root-card interactive-card leadership-card" 
                    style="--accent: #eab308"
                    data-name={techLead.name}
                    data-role={techLead.role}
                    data-speciality={techLead.speciality || ""}
                    data-about={techLead.about || ""}
                    data-photo={techLead.photoResolved || ""}
                    data-github={techLead.socials.github}
                    data-linkedin={techLead.socials.linkedin}
                    data-email={techLead.socials.email}
                    data-subdivision=""
                    data-avatar-gradient="linear-gradient(135deg, #fcd34d, #f59e0b)"
                  >
                    <div class="pcard-info">
                      <span class="pcard-name">{techLead.name}</span>
                      <span class="pcard-role">{techLead.role}</span>
                    </div>
                    <div class="pcard-avatar" style={techLead.photoResolved ? `background: url(${techLead.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, #fcd34d, #f59e0b)`}>
                      {!techLead.photoResolved && initials(techLead.name)}
                    </div>
                  </div>

                <!-- Administrative Lead connected as staff/assistant node (Karen Schuler style) -->
                {adminLead && (
                  <div class="staff-node">
                    <div class="staff-connector-h"></div>
                    <div 
                      class="pcard staff-card interactive-card leadership-card" 
                      style="--accent: #eab308"
                      data-name={adminLead.name}
                      data-role={adminLead.role}
                      data-speciality={adminLead.speciality || ""}
                      data-about={adminLead.about || ""}
                      data-photo={adminLead.photoResolved || ""}
                      data-github={adminLead.socials.github}
                      data-linkedin={adminLead.socials.linkedin}
                      data-email={adminLead.socials.email}
                      data-subdivision=""
                      data-avatar-gradient="linear-gradient(135deg, #fcd34d, #f59e0b)"
                    >
                      <div class="pcard-info">
                        <span class="pcard-name">{adminLead.name}</span>
                        <span class="pcard-role">{adminLead.role}</span>
                      </div>
                      <div class="pcard-avatar" style={adminLead.photoResolved ? `background: url(${adminLead.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, #fcd34d, #f59e0b)`}>
                        {!adminLead.photoResolved && initials(adminLead.name)}
                      </div>
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>

          <!-- Vertical connector line from Tech Lead to horizontal row -->
          <div class="main-trunk-line"></div>

          <!-- ── LEVEL 2: Team Leads and Subdivisions ── -->
          <div class="org-branches-row">
            {subdivisionMap.map(sub => {
              const tl = teamLeads.find(t => t.name === sub.teamLeadName);
              if (!tl) return null;
              const members = resolvedSubdivisions[sub.key] ?? [];
              const pms     = allPMs.filter(m => m.subdivision === sub.label);
              const mems    = members.filter(m => m.role === 'Member');

              return (
                <div class="org-branch-col">
                  <!-- Vertical connector from the parent horizontal bridge line -->
                  <div class="branch-connector-v"></div>

                  <!-- Team Lead Card -->
                  <div 
                    class="pcard branch-lead-card interactive-card" 
                    style={`--accent: ${sub.color}`}
                    data-name={tl.name}
                    data-role="Team Lead"
                    data-speciality={tl.speciality || ""}
                    data-about={tl.about || ""}
                    data-photo={tl.photoResolved || ""}
                    data-github={tl.socials.github}
                    data-linkedin={tl.socials.linkedin}
                    data-email={tl.socials.email}
                    data-subdivision={sub.label}
                    data-avatar-gradient={`linear-gradient(135deg, ${sub.color}aa, ${sub.color})`}
                  >
                    <div class="pcard-info">
                      <span class="pcard-name">{tl.name}</span>
                      <span class="pcard-role">Team Lead</span>
                      <span class="pcard-sub">{sub.label}</span>
                    </div>
                    <div class="pcard-avatar" style={tl.photoResolved ? `background: url(${tl.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, ${sub.color}aa, ${sub.color})`}>
                      {!tl.photoResolved && initials(tl.name)}
                    </div>
                  </div>

                  <!-- Subordinates (PMs and Members) in stacked lists with side lines -->
                  {(pms.length > 0 || mems.length > 0) && (
                    <div class="subordinates-list" style={`--accent-color: ${sub.color}`}>
                      
                      <!-- Project Managers Section -->
                      {pms.map(pm => (
                        <div class="subordinate-item">
                          <div 
                            class="pcard pm-card interactive-card pm-highlight" 
                            style={`--accent: ${sub.color}`}
                            data-name={pm.name}
                            data-role="Project Manager"
                            data-speciality={pm.speciality || ""}
                            data-about={pm.about || ""}
                            data-photo={pm.photoResolved || ""}
                            data-github={pm.socials.github}
                            data-linkedin={pm.socials.linkedin}
                            data-email={pm.socials.email}
                            data-subdivision={sub.label}
                            data-avatar-gradient={`linear-gradient(135deg, ${sub.color}88, ${sub.color}bb)`}
                          >
                            <div class="pcard-info">
                              <span class="pcard-name">{pm.name}</span>
                              <span class="pcard-role">Project Manager</span>
                            </div>
                            <div class="pcard-avatar" style={pm.photoResolved ? `background: url(${pm.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, ${sub.color}88, ${sub.color}bb)`}>
                              {!pm.photoResolved && initials(pm.name)}
                            </div>
                          </div>
                        </div>
                      ))}

                      <!-- Members Section -->
                      {mems.map(m => (
                        <div class="subordinate-item">
                          <div 
                            class="pcard mem-card interactive-card" 
                            style={`--accent: ${sub.color}`}
                            data-name={m.name}
                            data-role="Member"
                            data-speciality={m.speciality || ""}
                            data-about={m.about || ""}
                            data-photo={m.photoResolved || ""}
                            data-github={m.socials.github}
                            data-linkedin={m.socials.linkedin}
                            data-email={m.socials.email}
                            data-subdivision={sub.label}
                            data-avatar-gradient={`linear-gradient(135deg, ${sub.color}44, ${sub.color}77)`}
                          >
                            <div class="pcard-info">
                              <span class="pcard-name">{m.name}</span>
                              <span class="pcard-role">Member</span>
                            </div>
                            <div class="pcard-avatar" style={m.photoResolved ? `background: url(${m.photoResolved}) center/cover no-repeat` : `background: linear-gradient(135deg, ${sub.color}44, ${sub.color}77)`}>
                              {!m.photoResolved && initials(m.name)}
                            </div>
                          </div>
                        </div>
                      ))}

                    </div>
                  )}
                </div>
              );
            })}
          </div>

        </div>
      </div>
    </div>

    <!-- ══════════════════ GRID VIEW ══════════════════ -->
    <div id="view-grid" class="view-pane hidden">

      <section class="grid-section">
        <h2 class="section-title">Leadership</h2>
        <div class="member-grid">
          {allLeads.map(m => (
            <div 
              class="pcard grid-pcard interactive-card" 
              style="--accent:#0ea5e9"
              data-name={m.name}
              data-role={m.role}
              data-speciality={m.speciality || ""}
              data-about={m.about || ""}
              data-photo={m.photoResolved || ""}
              data-subdivision={m.subdivision || ""}
              data-github={m.socials.github}
              data-linkedin={m.socials.linkedin}
              data-email={m.socials.email}
              data-avatar-gradient="linear-gradient(135deg, #38bdf8, #0284c7)"
            >
              <div class="pcard-info">
                <span class="pcard-name">{m.name}</span>
                <span class="pcard-role">{m.role}</span>
                {m.subdivision && <span class="pcard-sub">{m.subdivision}</span>}
              </div>
              <div class="pcard-avatar" style={m.photoResolved ? `background: url(${m.photoResolved}) center/cover no-repeat` : `background:#0284c7`}>
                {!m.photoResolved && initials(m.name)}
              </div>
            </div>
          ))}
        </div>
      </section>

      {subdivisionMap.map(sub => {
        const pms = allPMs.filter(m => m.subdivision === sub.label);
        const members = resolvedSubdivisions[sub.key] ?? [];
        const allSubMembers = [...pms, ...members];
        if (!allSubMembers.length) return null;
        return (
          <section class="grid-section">
            <h2 class="section-title" style={`border-bottom-color:${sub.color}33`}>
              <span class="section-dot" style={`background:${sub.color}`}></span>
              {sub.label}
            </h2>
            <div class="member-grid">
              {allSubMembers.map(m => (
                <div 
                  class="pcard grid-pcard interactive-card" 
                  style={`--accent:${sub.color}`}
                  data-name={m.name}
                  data-role={m.role}
                  data-speciality={m.speciality || ""}
                  data-about={m.about || ""}
                  data-photo={m.photoResolved || ""}
                  data-subdivision={sub.label}
                  data-github={m.socials.github}
                  data-linkedin={m.socials.linkedin}
                  data-email={m.socials.email}
                  data-avatar-gradient={`linear-gradient(135deg, ${sub.color}aa, ${sub.color})`}
                >
                  <div class="pcard-info">
                    <span class="pcard-name">{m.name}</span>
                    <span class="pcard-role">{m.role}</span>
                  </div>
                  <div class="pcard-avatar" style={m.photoResolved ? `background: url(${m.photoResolved}) center/cover no-repeat` : `background:${sub.color}`}>
                    {!m.photoResolved && initials(m.name)}
                  </div>
                </div>
              ))}
            </div>
          </section>
        );
      })}

    </div>

    <!-- ══════════════════ MEMBER DETAIL MODAL ══════════════════ -->
    <div id="member-modal" class="modal-backdrop hidden" aria-modal="true" role="dialog">
      <div class="modal-content">
        <button class="modal-close" aria-label="Close details">&times;</button>
        
        <!-- Profile Header with large avatar -->
        <div class="modal-profile-header">
          <div id="modal-avatar" class="modal-avatar-large"></div>
          <h3 id="modal-name"></h3>
          <p id="modal-role"></p>
          <span id="modal-subdivision" class="modal-sub-badge"></span>
        </div>
        
        <div class="modal-divider"></div>
        
        <div class="modal-body">
          <!-- Field: Speciality -->
          <div class="modal-field">
            <span class="field-label">Speciality</span>
            <span id="modal-speciality" class="field-value"></span>
          </div>

          <!-- Field: About -->
          <div class="modal-field">
            <span class="field-label">About</span>
            <span id="modal-about" class="field-value text-muted"></span>
          </div>

          <!-- Field: Connect with me -->
          <div class="modal-field">
            <span class="field-label">Connect with me</span>
            <div class="modal-socials">
              <a id="modal-link-github" href="#" target="_blank" rel="noopener" class="social-btn" title="GitHub">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
              </a>
              <a id="modal-link-linkedin" href="#" target="_blank" rel="noopener" class="social-btn" title="LinkedIn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
              </a>
              <a id="modal-link-email" href="#" class="social-btn" title="Email">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

  </main>
</Layout>

<script is:inline>
(function () {
  function setupPage() {
    // ── View Switcher ──
    var btnOrg  = document.getElementById('btn-org');
    var btnGrid = document.getElementById('btn-grid');
    var viewOrg = document.getElementById('view-org');
    var viewGrid = document.getElementById('view-grid');

    if (!btnOrg || !btnGrid || !viewOrg || !viewGrid) return;

    function show(v) {
      if (v === 'org') {
        viewOrg.classList.remove('hidden');
        viewGrid.classList.add('hidden');
        btnOrg.classList.add('active');
        btnOrg.setAttribute('aria-pressed', 'true');
        btnGrid.classList.remove('active');
        btnGrid.setAttribute('aria-pressed', 'false');
      } else {
        viewGrid.classList.remove('hidden');
        viewOrg.classList.add('hidden');
        btnGrid.classList.add('active');
        btnGrid.setAttribute('aria-pressed', 'true');
        btnOrg.classList.remove('active');
        btnOrg.setAttribute('aria-pressed', 'false');
      }
    }

    btnOrg.addEventListener('click', function() { show('org'); });
    btnGrid.addEventListener('click', function() { show('grid'); });

    // ── Modal Dialog logic ──
    var modal = document.getElementById('member-modal');
    if (!modal) return;
    
    var modalClose = modal.querySelector('.modal-close');
    var modalName = document.getElementById('modal-name');
    var modalRole = document.getElementById('modal-role');
    var modalSpeciality = document.getElementById('modal-speciality');
    var modalAbout = document.getElementById('modal-about');
    var modalSubdivision = document.getElementById('modal-subdivision');
    var modalAvatar = document.getElementById('modal-avatar');
    
    var modalLinkGithub = document.getElementById('modal-link-github');
    var modalLinkLinkedin = document.getElementById('modal-link-linkedin');
    var modalLinkEmail = document.getElementById('modal-link-email');

    function getInitials(name) {
      return name.split(' ').map(function(w) { return w[0]; }).slice(0, 2).join('').toUpperCase();
    }

    document.querySelectorAll('.interactive-card').forEach(function(card) {
      card.addEventListener('click', function() {
        var name = card.getAttribute('data-name');
        var role = card.getAttribute('data-role');
        var speciality = card.getAttribute('data-speciality');
        var about = card.getAttribute('data-about');
        var photo = card.getAttribute('data-photo');
        var subdivision = card.getAttribute('data-subdivision');
        var avatarGradient = card.getAttribute('data-avatar-gradient');
        
        var github = card.getAttribute('data-github');
        var linkedin = card.getAttribute('data-linkedin');
        var email = card.getAttribute('data-email');

        if (!name) return;

        modalName.textContent = name;
        modalRole.textContent = role;
        modalSpeciality.textContent = speciality || 'N/A';
        modalAbout.textContent = about || 'Passionate engineer developing Rovah rover systems.';
        
        if (subdivision) {
          modalSubdivision.textContent = subdivision;
          modalSubdivision.classList.remove('hidden');
        } else {
          modalSubdivision.classList.add('hidden');
        }

        // Populate Social links
        if (github) {
          modalLinkGithub.href = github;
          modalLinkGithub.style.display = 'inline-flex';
        } else {
          modalLinkGithub.style.display = 'none';
        }

        if (linkedin) {
          modalLinkLinkedin.href = linkedin;
          modalLinkLinkedin.style.display = 'inline-flex';
        } else {
          modalLinkLinkedin.style.display = 'none';
        }

        if (email) {
          modalLinkEmail.href = 'mailto:' + email;
          modalLinkEmail.style.display = 'inline-flex';
        } else {
          modalLinkEmail.style.display = 'none';
        }

        // Photo / Avatar Render
        if (photo) {
          modalAvatar.style.background = 'url(' + photo + ') center/cover no-repeat';
          modalAvatar.textContent = '';
        } else {
          modalAvatar.textContent = getInitials(name);
          modalAvatar.style.background = avatarGradient || 'linear-gradient(135deg, #38bdf8, #0284c7)';
        }

        modal.classList.remove('hidden');
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      });
    });

    function closeModal() {
      modal.classList.remove('active');
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    }

    if (modalClose) modalClose.addEventListener('click', closeModal);
    
    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        closeModal();
      }
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
      }
    });
  }

  // Bind to Astro view transition hook so it fires on AJAX navigations
  document.addEventListener('astro:page-load', setupPage);
})();
</script>

<style>
/* ─── Page base ──────────────────────────────────────────────────────────── */
.team-page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 5rem;
